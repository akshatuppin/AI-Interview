{
    "version": "0.2.0",
    "configurations": [
        
        {
            "name": "Launch Chrome",
            "request": "launch",
            "type": "chrome",
            "url": "http://localhost:8081",
            "webRoot": "${workspaceFolder}"
        },
        {
            "type": "java",
            "name": "AiInterviewApplication",
            "request": "launch",
            "mainClass": "com.interview.AiInterviewApplication",
            "projectName": "AI-Interview",
            "envFile": "${workspaceFolder}/backend/.env"
        }
    ]
}
